{
  "name": "horus-cli",
  "version": "0.1.0",
  "description": "The All-Seeing Gateway — Navigate and run project commands without memorization.",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "hrs":   "./dist/bin/horus.js",
    "horus": "./dist/bin/horus.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bin/horus.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "execa":          "^9.5.2",
    "picocolors":     "^1.1.1",
    "zod":            "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "interactive",
    "productivity",
    "cross-platform"
  ],
  "author": "",
  "license": "MIT"
}
